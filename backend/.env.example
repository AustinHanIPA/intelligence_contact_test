# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/intelligent_contact
DATABASE_URL_SYNC=postgresql://postgres:password@localhost:5432/intelligent_contact

# Redis
REDIS_URL=redis://localhost:6379/0

# OpenAI / LLM
OPENAI_API_KEY=your-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4

# Embedding
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# JWT
SECRET_KEY=your-secret-key-here
ACCESS_TOKEN_EXPIRE_MINUTES=60

# App
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO
